{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "overlay",
  "version": "0.1.0",
  "identifier": "com.tauri-app.overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "overlay",
        "width": 1080,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "devtools": true,
        "dragDropEnabled": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
